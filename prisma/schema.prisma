generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  emailVerifiedAt   DateTime?
  password          String
  isAdmin           Boolean   @default(false)
  rememberToken     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Registration {
  id                      String    @id @default(cuid())
  fullName                String
  nickname                String?
  gender                  String
  birthPlace              String
  birthDate               DateTime
  religion                String?
  address                 String
  city                    String?
  province                String?
  postalCode              String?
  whatsapp                String    @unique
  email                   String?   @unique
  class                   String
  major                   String
  bloodType               String?
  medicalHistory          String?
  organizationExperience String?
  motivation              String
  status                  String    @default("pending")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([status])
  @@index([email])
  @@index([whatsapp])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
}

model OrganizationMember {
  id           String   @id @default(cuid())
  name         String
  nickname     String?
  position     String
  division     String?
  divisionDesc String?
  bio          String?
  photo        String?
  level        Int      @default(0)
  parentId     String?
  sortOrder    Int      @default(0)
  period       String   @default("2024/2025")
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent  OrganizationMember?  @relation("OrganizationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children OrganizationMember[] @relation("OrganizationTree")

  @@index([level])
  @@index([parentId])
  @@index([sortOrder])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String   @default("Admin PARSTAMA")
  category    String   @default("Kesehatan")
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([category])
  @@index([createdAt])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  color       String   @default("#DC2626")
  category    String   @default("Kegiatan")
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate])
  @@index([isVisible])
  @@index([category])
}