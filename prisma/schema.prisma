generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  emailVerifiedAt   DateTime?
  password          String
  isAdmin           Boolean   @default(false)
  rememberToken     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([isAdmin])
  @@index([email])
}

model Registration {
  id                      String    @id @default(cuid())
  fullName                String
  nickname                String?
  gender                  String
  birthPlace              String
  birthDate               DateTime
  religion                String?
  address                 String
  city                    String?
  province                String?
  postalCode              String?
  whatsapp                String    @unique
  email                   String?   @unique
  class                   String
  major                   String
  bloodType               String?
  medicalHistory          String?
  organizationExperience String?
  motivation              String
  motivationScore         Int?
  sentimentLabel          String?
  parentConsent           Boolean   @default(false)
  status                  String    @default("pending")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([status])
  @@index([email])
  @@index([whatsapp])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([class])
  @@index([major])
  @@index([gender])
  @@index([class, major])
  @@index([status, class, major])
}

model OrganizationMember {
  id            String   @id @default(cuid())
  name          String
  nickname      String?
  position      String
  division      String?
  divisionDesc  String?
  bio           String?
  photo         String?
  level         Int      @default(0)
  parentId      String?
  sortOrder     Int      @default(0)
  period        String?
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
  @@index([isVisible])
  @@index([division])
  @@index([level, sortOrder])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String   @default("Admin PARSTAMA")
  category    String   @default("Kesehatan")
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([category])
  @@index([createdAt])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  color       String    @default("#DC2626")
  category    String    @default("Kegiatan")
  isVisible   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isVisible])
  @@index([startDate])
  @@index([category])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  userEmail String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(1)
  expiresAt DateTime

  @@index([key, expiresAt])
}
